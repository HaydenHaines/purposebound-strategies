---
// src/components/HeroAlt.astro
import { theme } from '../../theme.config';
const base = import.meta.env.BASE_URL;
---
<section class="border-b-[3px] border-accent min-h-[520px] relative overflow-hidden bg-deep flex items-center">
  <!-- Hero background image -->
  <img
    src={`${base}/images/hero.png`}
    alt=""
    aria-hidden="true"
    class="absolute inset-0 w-full h-full object-cover object-center pointer-events-none select-none z-[0]"
  />

  <!-- Gradient overlay for text legibility -->
  <div class="absolute inset-0 bg-gradient-to-r from-deep/95 via-deep/70 to-deep/20 z-[1]"></div>

  <!-- Text content: z-10 always on top -->
  <div class="relative z-10 pl-16 pr-10 py-16 flex flex-col justify-center max-w-3xl">
    <p class="font-inter text-accent text-xs uppercase tracking-[0.3em] mb-5 whitespace-nowrap">
      Kingdom ✦ Marketplace ✦ Ministry
    </p>
    <h1 class="font-display uppercase text-cream font-bold leading-none mb-6" style="font-size: clamp(2.8rem, 6vw, 5rem); letter-spacing: 0.02em;">
      Build a Business That Honors <span class="text-accent">Something Greater.</span>
    </h1>
    <p class="text-muted text-base leading-relaxed max-w-md mb-8">
      Your business is a mission field. We help faith-driven leaders build cultures
      that form people, not just drive performance.
    </p>
    <div class="flex gap-3 flex-wrap">
      <a
        href={`${base}/contact`}
        class="font-inter border border-cream text-cream text-xs uppercase tracking-wider px-6 py-3 hover:bg-cream hover:text-deep transition-all"
      >
        Let's Talk
      </a>
      <a
        href={`${base}/start`}
        class="font-inter bg-accent text-deep text-xs font-bold uppercase tracking-wider px-6 py-3 hover:brightness-110 transition-all"
      >
        Get the Free Guide
      </a>
    </div>
  </div>
</section>

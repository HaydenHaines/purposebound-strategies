---
// src/components/Hero.astro
import { theme } from '../../theme.config';
const base = import.meta.env.BASE_URL;
---
<section class="bg-rich border-b-[3px] border-accent flex items-stretch min-h-[520px] relative overflow-hidden">
  <!-- Background photo with dark overlay -->
  <div class="absolute inset-0 z-0">
    <img
      src={`${base}/images/mission-trip.jpg`}
      alt=""
      aria-hidden="true"
      class="w-full h-full object-cover object-center"
    />
    <div class="absolute inset-0 bg-deep/94"></div>
  </div>

  <!-- Watermark logo behind text -->
  <img
    src={`${base}${theme.brand.logo}`}
    alt=""
    aria-hidden="true"
    class="absolute left-0 top-1/2 -translate-y-1/2 h-[90%] opacity-[0.06] object-contain pointer-events-none select-none z-[1]"
  />

  <!-- Left: copy + CTAs -->
  <div class="flex-1 pl-16 pr-10 py-14 flex flex-col justify-center relative z-10 bg-deep/55 backdrop-blur-sm">
    <p class="font-inter text-accent text-xs uppercase tracking-[0.3em] mb-4 [text-shadow:0_1px_8px_rgba(0,0,0,0.8)]">
      Corporate Ministry · Workplace Discipleship · Spiritual Leadership
    </p>
    <h1 class="text-cream font-heading text-6xl font-bold leading-tight mb-5 [text-shadow:0_2px_24px_rgba(0,0,0,0.9)]">
      Build a Business That<br />
      Honors <span class="text-accent">Something Greater.</span>
    </h1>
    <p class="text-muted text-base leading-relaxed max-w-md mb-8 [text-shadow:0_1px_12px_rgba(0,0,0,0.8)]">
      For faith-driven leaders who know their organization is called to more —
      Tory walks alongside ownership and teams to cultivate spiritual health,
      Kingdom purpose, and a culture that forms people, not just drives performance.
    </p>
    <div class="flex gap-3 flex-wrap">
      <a
        href={`${base}/start`}
        class="font-inter bg-accent text-deep text-xs font-bold uppercase tracking-wider px-6 py-3 hover:brightness-110 transition-all"
      >
        Get the Free Guide
      </a>
      <a
        href={`${base}/contact`}
        class="font-inter border border-cream text-cream text-xs uppercase tracking-wider px-6 py-3 hover:bg-cream hover:text-deep transition-all"
      >
        Start a Conversation
      </a>
    </div>
  </div>

  <!-- Right: founder photo full hero height -->
  <div class="w-72 flex-shrink-0 overflow-hidden relative z-10">
    <img
      src={`${base}${theme.founder.photo}`}
      alt={theme.founder.name}
      class="w-full h-full object-cover object-top"
    />
  </div>
</section>

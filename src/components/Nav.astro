---
// src/components/Nav.astro
import { theme } from '../../theme.config';
---
<nav class="bg-deep px-8 py-4 flex justify-between items-center">
  <a href="/" class="flex items-center gap-3">
    <span class="font-inter text-cream text-sm font-bold uppercase tracking-[0.15em]">
      {theme.site.name}
    </span>
  </a>
  <div class="flex items-center gap-6">
    {theme.nav.map((item) => (
      <a href={`${item.href}`} class="font-inter text-accent text-xs uppercase tracking-wider hover:text-cream transition-colors">
        {item.label}
      </a>
    ))}
    <a
      href={`/contact`}
      class="font-inter bg-accent text-deep text-xs font-bold uppercase tracking-wider px-4 py-2 hover:brightness-110 transition-all"
    >
      Let's Talk
    </a>
  </div>
</nav>

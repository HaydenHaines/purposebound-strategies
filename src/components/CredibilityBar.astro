---
// src/components/CredibilityBar.astro
import { theme } from '../../theme.config';
---
{theme.credibility.length > 0 && (
  <div class="bg-cream border-y border-muted/30 px-8 py-5 text-center">
    <p class="text-pb-text/50 text-[9px] uppercase tracking-[0.25em] mb-3">{theme.credibilityLabel}</p>
    <div class="flex justify-center items-center gap-8 flex-wrap">
      {theme.credibility.map((item) => (
        item.url
          ? <a href={item.url} class="text-pb-text/70 text-sm hover:text-link transition-colors">{item.name}</a>
          : <span class="text-pb-text/70 text-sm">{item.name}</span>
      ))}
    </div>
  </div>
)}

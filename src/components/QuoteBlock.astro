---
// src/components/QuoteBlock.astro
interface Props {
  quote: string;
  linkText?: string;
  linkHref?: string;
  light?: boolean;
}
const { quote, linkText, linkHref, light = false } = Astro.props;
---
<blockquote class="border-l-4 border-accent pl-6 py-2">
  <p class={`${light ? 'text-cream' : 'text-pb-text'} text-lg font-bold leading-relaxed italic mb-3`}>
    "{quote}"
  </p>
  {linkText && linkHref && (
    <a href={linkHref} class={`${light ? 'text-muted' : 'text-burgundy'} text-xs uppercase tracking-widest hover:text-accent transition-colors`}>
      → {linkText}
    </a>
  )}
</blockquote>

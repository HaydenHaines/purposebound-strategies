---
// src/components/TestimonialScroller.astro
interface Testimonial {
  name: string;
  title: string;
  company: string;
  quote: string;
  result?: string;
}
interface Props {
  testimonials: Testimonial[];
}
const { testimonials } = Astro.props;
---
<section class="bg-cream px-10 py-14 text-center">
  <!-- All slides share the same grid cell; container height = tallest slide -->
  <div class="grid">
    {testimonials.map((t, i) => (
      <div
        class="col-start-1 row-start-1 testimonial-slide transition-opacity duration-500 flex flex-col items-center"
        data-slide={i}
        style={i === 0 ? 'opacity:1;' : 'opacity:0;pointer-events:none;'}
      >
        <div class="text-link text-5xl mb-4 font-heading">"</div>
        <blockquote class="text-pb-text text-lg font-semibold leading-relaxed max-w-xl mx-auto italic mb-4">
          {t.quote}
        </blockquote>
        {t.result && (
          <p class="text-accent text-sm font-bold uppercase tracking-wider mb-4">{t.result}</p>
        )}
        <p class="text-pb-text/50 text-xs uppercase tracking-wider">
          — {t.name}, {t.title}, {t.company}
        </p>
      </div>
    ))}
  </div>

  <!-- Navigation: arrows + dots -->
  <div class="flex items-center justify-center gap-4 mt-8">
    <button
      class="testimonial-prev text-deep/50 hover:text-accent transition-colors text-2xl leading-none px-2 font-bold"
      aria-label="Previous testimonial"
    >&#8592;</button>
    <div class="flex gap-2">
      {testimonials.map((_, i) => (
        <button
          class={`testimonial-dot w-2.5 h-2.5 rounded-full transition-colors ${i === 0 ? 'bg-accent' : 'bg-muted'}`}
          data-target={i}
          aria-label={`Show testimonial ${i + 1}`}
        />
      ))}
    </div>
    <button
      class="testimonial-next text-deep/50 hover:text-accent transition-colors text-2xl leading-none px-2 font-bold"
      aria-label="Next testimonial"
    >&#8594;</button>
  </div>
</section>

<script>
  const section = document.querySelector<HTMLElement>('.testimonial-slide')!.closest('section')!;
  const slides = section.querySelectorAll<HTMLElement>('.testimonial-slide');
  const dots = section.querySelectorAll<HTMLButtonElement>('.testimonial-dot');
  const prevBtn = section.querySelector<HTMLButtonElement>('.testimonial-prev')!;
  const nextBtn = section.querySelector<HTMLButtonElement>('.testimonial-next')!;
  let current = 0;
  let timer: ReturnType<typeof setTimeout>;

  function goTo(n: number) {
    slides[current].style.opacity = '0';
    slides[current].style.pointerEvents = 'none';
    dots[current].classList.remove('bg-accent');
    dots[current].classList.add('bg-muted');
    current = ((n % slides.length) + slides.length) % slides.length;
    slides[current].style.opacity = '1';
    slides[current].style.pointerEvents = '';
    dots[current].classList.remove('bg-muted');
    dots[current].classList.add('bg-accent');
  }

  function schedule() {
    clearTimeout(timer);
    timer = setTimeout(() => { goTo(current + 1); schedule(); }, 7000);
  }

  dots.forEach((dot, i) => {
    dot.addEventListener('click', () => { goTo(i); schedule(); });
  });
  prevBtn.addEventListener('click', () => { goTo(current - 1); schedule(); });
  nextBtn.addEventListener('click', () => { goTo(current + 1); schedule(); });

  schedule();
</script>

---
// src/pages/blog/[...slug].astro
// Detail route for blog posts. Generates one static page per non-draft post.
import Page from '../../layouts/Page.astro';
import SectionLabel from '../../components/SectionLabel.astro';
import { getCollection, type CollectionEntry } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => !data.draft);
  return posts.map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

type Props = { post: CollectionEntry<'blog'> };
const { post } = Astro.props;
const { Content } = await post.render();
const dateLabel = post.data.pubDate.toLocaleDateString('en-US', {
  month: 'long',
  day: 'numeric',
  year: 'numeric',
});
---
<Page title={post.data.title} description={post.data.description}>
  <!-- Post header -->
  <section class="bg-rich border-b-[3px] border-accent px-10 py-16 text-center">
    <SectionLabel text="From the Blog" light />
    <h1 class="text-cream text-4xl font-bold mb-4 max-w-2xl mx-auto leading-tight">
      {post.data.title}
    </h1>
    <p class="text-accent text-[10px] uppercase tracking-[0.25em]">
      {dateLabel} · {post.data.author}
    </p>
  </section>

  <!-- Post body -->
  <section class="bg-cream px-10 py-14">
    <article class="post-body max-w-2xl mx-auto text-pb-text">
      <Content />
    </article>

    <div class="max-w-2xl mx-auto mt-12 pt-8 border-t border-muted/30">
      <a href={`/blog`} class="text-link text-sm hover:text-accent transition-colors">
        ← Back to all posts
      </a>
    </div>
  </section>
</Page>

<style>
  /* Markdown body is injected via <Content />, so its child tags need :global()
     to receive styling (Astro's scoping attribute is never added to them). */
  .post-body :global(p) {
    color: rgb(19 34 64 / 0.8); /* pb-text @ 80% */
    font-size: 1rem;
    line-height: 1.75;
    margin-bottom: 1.25rem;
  }
  .post-body :global(h2) {
    color: var(--color-text);
    font-weight: 700;
    font-size: 1.5rem;
    line-height: 1.3;
    margin-top: 2rem;
    margin-bottom: 1rem;
  }
  .post-body :global(h3) {
    color: var(--color-text);
    font-weight: 700;
    font-size: 1.2rem;
    margin-top: 1.5rem;
    margin-bottom: 0.75rem;
  }
  .post-body :global(ul) {
    list-style: none;
    margin-bottom: 1.25rem;
    padding-left: 0;
  }
  .post-body :global(li) {
    color: rgb(19 34 64 / 0.8);
    font-size: 1rem;
    line-height: 1.7;
    padding-left: 1.5rem;
    position: relative;
    margin-bottom: 0.5rem;
  }
  .post-body :global(li)::before {
    content: '→';
    color: var(--color-accent);
    font-weight: 700;
    position: absolute;
    left: 0;
  }
  .post-body :global(blockquote) {
    border-left: 4px solid var(--color-accent);
    padding: 0.25rem 0 0.25rem 1.25rem;
    margin: 1.5rem 0;
    font-style: italic;
    font-weight: 700;
    color: rgb(19 34 64 / 0.85);
  }
  .post-body :global(a) {
    color: var(--color-link);
    text-decoration: underline;
  }
  .post-body :global(strong) {
    color: var(--color-text);
    font-weight: 700;
  }
</style>
